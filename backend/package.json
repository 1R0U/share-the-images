{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply share_the_images --local",
    "db:migrate:remote": "wrangler d1 migrations apply share_the_images --remote"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "kysely": "^0.28.14",
    "kysely-d1": "^0.4.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.2.3",
    "vite": "^6.3.5",
    "vite-ssr-components": "^0.5.2",
    "wrangler": "^4.17.0"
  }
}
